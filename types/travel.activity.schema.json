{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eventcal.org/ext/travel.activity/v1",
  "x-eventcal-type": "travel.activity",
  "title": "details de travel.activity",
  "type": "object",
  "required": ["activity"],
  "additionalProperties": false,
  "properties": {
    "activity": { "enum": ["sightseeing", "food", "transport", "lodging", "other"] },
    "booking": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ref": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "cost": {
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "nextTravel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["walk", "transit", "car", "bike", "flight"] },
        "minutes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
